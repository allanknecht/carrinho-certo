<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CarrinhoCerto.Pages.AccountPage"
             BackgroundColor="#F2F2F2"
             Title="AccountPage">

    <Grid RowDefinitions="Auto, *">

        <ContentView Grid.Row="0"
                     BackgroundColor="#FEF035"
                     Padding="0, 15, 0, 15">
            <Image Source="logohorizontal.png"
                   HorizontalOptions="Center"
                   WidthRequest="200"/>
        </ContentView>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="25">

                <VerticalStackLayout Spacing="10">


                    <Border BackgroundColor="White"
                    Stroke="#E0E0E0"
                    StrokeThickness="1"
                    Padding="15">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="15">
                            <Image Source="account.svg"
                                   WidthRequest="30" HeightRequest="30"
                                   VerticalOptions="Center"/>

                            <VerticalStackLayout HorizontalOptions="Center">
                                <Label Text="Usuário Logado"
                                       TextColor="#616161"
                                       FontFamily="PoppinsBold" FontSize="14"
                                       Margin="0,0,0,-5"/>

                                <Label Text="usuario.logado@email.com.br"
                                       TextColor="#9E9E9E"
                                       FontFamily="PoppinsRegular"
                                       FontSize="12" HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="Configurações"
                           TextColor="#616161"
                           FontFamily="PoppinsBold"
                           FontSize="16"
                           Margin="0,10,0,0"/>

                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="15">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>

                        <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                            <Label Text=">"
                                   TextColor="#B30000"
                                   FontFamily="PoppinsBold" FontSize="14" />

                            <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                                <Label Text="Alterar Senha"
                                       TextColor="#616161"
                                       FontFamily="PoppinsBold" FontSize="14" />

                            </VerticalStackLayout>
                        </HorizontalStackLayout>


                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10" Margin="0,-10,0,0">


                    <Border BackgroundColor="White"
                            Stroke="#E0E0E0"
                            StrokeThickness="1"
                            Padding="15">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15" />
                        </Border.StrokeShape>

                        <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                            <Label Text=">"
                                   TextColor="#B30000"
                                   FontFamily="PoppinsBold"
                                   FontSize="14" />

                            <VerticalStackLayout VerticalOptions="Center" Spacing="0">
                                <Label Text="Notificações"
                                       TextColor="#616161"
                                       FontFamily="PoppinsBold"
                                       FontSize="14" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <Border BackgroundColor="#E80000"
                        StrokeThickness="0"
                        HeightRequest="50">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>

                    <Grid>
                        <Ellipse x:Name="RippleEnviar" 
                                Fill="#B30000" 
                                Opacity="0"
                                HorizontalOptions="Start" 
                                VerticalOptions="Start" />

                        <Label Text="SAIR DO APP"
                           TextColor="#FEF035"
                           FontFamily="PoppinsBlack"
                           FontSize="25"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
                    </Grid>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSairContaTapped"/>
                    </Border.GestureRecognizers>
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
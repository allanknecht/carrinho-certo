# Development: Rails server + PostgreSQL client, code mounted via compose
ARG RUBY_VERSION=3.3.7
FROM docker.io/library/ruby:${RUBY_VERSION}-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y build-essential curl libpq-dev libyaml-dev postgresql-client && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

WORKDIR /rails

ENV BUNDLE_PATH=/usr/local/bundle

COPY Gemfile Gemfile.lock ./
RUN bundle install

# Lives outside /rails so the host volume never overwrites it; strips CRLF from mounted bin/ at runtime.
COPY docker-entrypoint-wrapper.sh /docker-entrypoint-wrapper.sh
RUN chmod +x /docker-entrypoint-wrapper.sh && sed -i "s/\r$//g" /docker-entrypoint-wrapper.sh

COPY . .

# Ensure binstubs are executable and use `ruby` instead of `ruby.exe`
RUN chmod +x bin/* && \
    sed -i "s/\r$//g" bin/* && \
    sed -i 's/ruby\.exe$/ruby/' bin/*

EXPOSE 3000

# Wrapper fixes CRLF on Windows-mounted /rails/bin, then runs bin/docker-entrypoint-dev.
ENTRYPOINT ["/docker-entrypoint-wrapper.sh"]
CMD ["bin/rails", "server", "-b", "0.0.0.0"]
